# ============================================================
# DOMINION REALMS — BACKEND ENV
# Скопируй в .env и заполни своими значениями
# ============================================================

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://dominion:dominion_secret@localhost:5432/dominion_realms
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=dominion
DATABASE_PASSWORD=dominion_secret
DATABASE_NAME=dominion_realms

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production_minimum_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=another_super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRES=30d

# Email (настрой позже)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@dominionrealms.com

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Game tick interval (ms) — ресурсы пересчитываются каждые N ms
RESOURCE_TICK_INTERVAL=60000
